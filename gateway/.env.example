GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8789
GATEWAY_API_KEY=replace-with-a-long-random-value
HEALTH_REQUIRES_AUTH=true

PUBLIC_BASE_URL=
AUDIO_PUBLIC_BASE_URL=

UPLOAD_DIR=storage/uploads
AUDIO_DIR=storage/audio
MAX_UPLOAD_MB=25

STT_PROVIDER=hermes
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=whisper-1
HERMES_STT_PYTHON=/path/to/.hermes/hermes-agent/venv/bin/python

TTS_PROVIDER=hermes
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy
HERMES_TTS_PYTHON=/path/to/.hermes/hermes-agent/venv/bin/python

HERMES_MODE=cli
HERMES_CLI_COMMAND=hermes
HERMES_CLI_ARGS_TEMPLATE=-z {prompt}
HERMES_AGENT=main
HERMES_TIMEOUT_MS=120000

HERMES_HTTP_BASE_URL=
HERMES_HTTP_API_KEY=
HERMES_HTTP_TURN_PATH=/agent/turn

MOCK_MODE=false
